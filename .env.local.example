# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> Data API (and API Keys)
#
# These NEXT_PUBLIC_* values are safe to expose in the browser.
# The anon key is protected by Row Level Security (RLS) — never put the
# service_role key in a NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
